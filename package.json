{
  "name": "code-ref",
  "displayName": "Code Ref",
  "description": "Copy absolute-path code references to clipboard, with macOS Kitty handoff for AI CLI tools",
  "publisher": "Xin",
  "version": "1.0.2",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Learner-Geek-Perfectionist/code-ref.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-ref.sendReference",
        "title": "Copy Code Reference"
      }
    ],
    "keybindings": [
      {
        "command": "code-ref.sendReference",
        "key": "alt+k",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test out/**/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
