{
  "name": "code-ref",
  "displayName": "Code Ref",
  "description": "Copy selected VS Code text as absolute-path code references with an opt-in smart copy shortcut",
  "publisher": "Xin",
  "version": "1.1.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Learner-Geek-Perfectionist/code-ref.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "code-ref.copyReference",
        "title": "Copy Code Reference"
      },
      {
        "command": "code-ref.toggleSmartCopy",
        "title": "Toggle Code Ref Smart Copy"
      }
    ],
    "keybindings": [
      {
        "command": "code-ref.copyReference",
        "key": "ctrl+c",
        "mac": "cmd+c",
        "when": "code-ref.smartCopyEnabled && editorTextFocus && editorHasSelection"
      }
    ],
    "configuration": {
      "title": "Code Ref",
      "properties": {
        "code-ref.smartCopy.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "application",
          "description": "Enable Smart Copy globally. When enabled, the platform copy shortcut copies selected editor text as an absolute-path code reference."
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "compile": "tsc -p ./",
    "test": "npm run clean && npm run compile && node --test out/**/*.test.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.3.0"
  }
}
